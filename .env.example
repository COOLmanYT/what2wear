# ================================================================
# skystyle — Environment Variables
# Copy this file to .env.local for local development.
# Set these variables in your Vercel project settings for deployment.
# ================================================================

# ----------------------------------------------------------------
# NextAuth (Auth.js v5)
# Generate AUTH_SECRET with: npx auth secret
# Set AUTH_URL to your deployment URL (e.g. https://example.com)
# ----------------------------------------------------------------
AUTH_SECRET=
AUTH_URL=

# GitHub OAuth App (https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth App (https://console.cloud.google.com/)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ----------------------------------------------------------------
# Supabase (https://supabase.com/dashboard)
# Found under: Project Settings → API
# ----------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------
# OpenAI (https://platform.openai.com/api-keys)
# Used for AI outfit recommendations (gpt-4o)
# Either OPENAI_API_KEY or GEMINI_API_KEY must be set.
# If both are set, OpenAI takes priority.
# ----------------------------------------------------------------
OPENAI_API_KEY=

# ----------------------------------------------------------------
# Google Gemini (https://aistudio.google.com/app/apikey)
# Alternative AI provider — used when OPENAI_API_KEY is not set.
# ----------------------------------------------------------------
GEMINI_API_KEY=

# ----------------------------------------------------------------
# OpenWeatherMap (https://openweathermap.org/api)
# Used for weather data outside Australia (free tier is sufficient)
# ----------------------------------------------------------------
OPENWEATHER_API_KEY=

# ----------------------------------------------------------------
# WeatherAPI.com (https://www.weatherapi.com/)
# Optional additional weather source for multi-source aggregation
# ----------------------------------------------------------------
WEATHERAPI_KEY=

# ----------------------------------------------------------------
# Visual Crossing (https://www.visualcrossing.com/)
# Optional additional weather source for multi-source aggregation
# ----------------------------------------------------------------
VISUALCROSSING_API_KEY=

# ----------------------------------------------------------------
# Pirate Weather (https://pirateweather.net/)
# Optional additional weather source for multi-source aggregation
# ----------------------------------------------------------------
PIRATEWEATHER_API_KEY=

# ----------------------------------------------------------------
# Dev Mode
# Comma-separated list of email addresses granted dev privileges.
# Dev users bypass all rate limits and can use the dev chat.
# Example: DEV_EMAILS=alice@example.com,bob@example.com
# ----------------------------------------------------------------
DEV_EMAILS=
